{
  "name": "mathbox-react",
  "version": "0.0.0",
  "description": "React wrapper for Mathbox",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristopherChudzicki/mathbox-react",
    "directory": "mathbox-react"
  },
  "author": "Chris Chudzicki",
  "main": "build/cjs/index.js",
  "exports": {
    ".": {
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    },
    "./threestrap": {
      "import": "./build/esm/threestrap/index.js",
      "require": "./build/cjs/threestrap/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "rm -rf ./build && yarn build-esm && yarn build-cjs",
    "build-esm": "tsc --project tsconfig.esm.json",
    "build-cjs": "tsc --project tsconfig.cjs.json",
    "build-watch": "tsc --watch",
    "storybook": "start-storybook -p 6006",
    "lint": "eslint \"**/*.ts?(x)\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@mathbox-react/eslint-config": "*",
    "@mathbox-react/tsconfig": "*",
    "@storybook/addon-actions": "7.6.24",
    "@storybook/addon-essentials": "7.6.24",
    "@storybook/addon-interactions": "7.6.24",
    "@storybook/addon-links": "7.6.24",
    "@storybook/builder-webpack5": "^7.0.0",
    "@storybook/manager-webpack5": "^6.5.15",
    "@storybook/react": "7.6.24",
    "@storybook/testing-library": "0.2.2",
    "@testing-library/react": "14.3.1",
    "@types/lodash": "4.17.24",
    "@types/react": "18.2.28",
    "@types/three": "0.162.0",
    "babel-loader": "9.2.1",
    "conventional-changelog-conventionalcommits": "^9",
    "eslint": "^8.32.0",
    "jsdom": "^29",
    "mathbox": "2.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "semantic-release": "^25",
    "three": "0.162.0",
    "typescript": "^5.2.2",
    "vitest": "^4"
  },
  "peerDependencies": {
    "mathbox": "^2.3.1",
    "react": "^17.0.2 || ^18.0.0",
    "three": ">=0.118.0 <0.163"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  }
}
